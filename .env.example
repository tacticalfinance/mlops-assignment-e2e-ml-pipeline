# ── Inference ─────────────────────────────────────────────────────────────────
NEBIUS_API_KEY=XXX

# ── MLflow tracking ────────────────────────────────────────────────────────────
# URI of the MLflow tracking server.
# Standalone mode:   http://localhost:5000
# Docker Compose:    http://mlflow:5000  (resolved inside the compose network)
MLFLOW_TRACKING_URI=http://localhost:5000

# ── S3 / Object Storage (optional – extra credit) ─────────────────────────────
# Leave these blank if you are not using remote artifact storage.
# For Nebius Object Storage, set S3_ENDPOINT_URL to the Nebius S3 endpoint.
S3_ENDPOINT_URL=
S3_BUCKET=mlops-assignment-artifacts
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
